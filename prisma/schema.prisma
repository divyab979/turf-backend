generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String     @id @default(cuid())
  name        String
  email       String     @unique
  password    String
  role        Role
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  venueId     String?
  phone       String?
  isSuspended Boolean    @default(false)
  bookings    Booking[]
  slotLocks   SlotLock[]
  venue       Venue?     @relation("VenueStaff", fields: [venueId], references: [id])
  ownedVenues Venue[]
}

model Venue {
  id        String    @id @default(cuid())
  name      String
  location  String
  address   String?
  ownerId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
  turfs     Turf[]
  staff     User[]    @relation("VenueStaff")
  owner     User      @relation(fields: [ownerId], references: [id])
  maintenanceIssues MaintenanceIssue[]

  businessType  String       @default("TURF")
  bookingMode   String       @default("FIXED_SLOTS")
  gamesHosted   String[]
  numPoolTables Int?
  numSnookerTables Int?
  numTvScreens  Int?
  numPsConsoles Int?
  numControllers Int?
  description   String?
  amenities     String[]
  images        VenueImage[]
}

model Turf {
  id          String      @id @default(cuid())
  name        String
  venueId     String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  sport       SportType
  description String?
  isActive    Boolean     @default(true)
  bookings    Booking[]
  slots       Slot[]
  venue       Venue       @relation(fields: [venueId], references: [id])
  images      TurfImage[]
  maintenanceIssues MaintenanceIssue[]
}

model Slot {
  id        String     @id @default(cuid())
  date      DateTime
  startTime String
  endTime   String
  turfId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  status    SlotStatus
  duration  Int
  price     Int
  bookings  Booking[]
  turf      Turf       @relation(fields: [turfId], references: [id])
  locks     SlotLock[]
}

model Booking {
  id                String        @id @default(cuid())
  customerName      String
  customerPhone     String
  slotId            String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  paymentStatus     PaymentStatus
  advancePaid       Int
  bookingDate       DateTime
  status            BookingStatus
  totalAmount       Int
  turfId            String?
  userId            String
  venueId           String
  expiresAt         DateTime?
  paidAt            DateTime?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  refundedAt        DateTime?
  refundedBy        String?
  remainingAmount   Int?
  cashPaymentRequested Boolean @default(false)

  startTime         String?
  endTime           String?
  gameActivity      String?
  paymentMethod     String?
  notes             String?

  slot              Slot?         @relation(fields: [slotId], references: [id])
  turf              Turf?         @relation(fields: [turfId], references: [id])
  user              User          @relation(fields: [userId], references: [id])
  venue             Venue         @relation(fields: [venueId], references: [id])
}

model TurfImage {
  id        String   @id @default(cuid())
  url       String
  turfId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  turf      Turf     @relation(fields: [turfId], references: [id])
}

model SlotLock {
  id        String         @id @default(cuid())
  slotId    String
  userId    String
  expiresAt DateTime
  status    SlotLockStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  slot      Slot           @relation(fields: [slotId], references: [id])
  user      User           @relation(fields: [userId], references: [id])
}

enum Role {
  SUPER_ADMIN
  VENUE_OWNER
  MANAGER
  STAFF
  CUSTOMER
}

enum SlotStatus {
  AVAILABLE
  BLOCKED
  BOOKED
  MAINTENANCE
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  FAILED
  REFUNDED
}

enum SportType {
  FOOTBALL
  CRICKET
  BADMINTON
  TENNIS
  PICKLEBALL
  SNOOKER
  POOL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum SlotLockStatus {
  ACTIVE
  EXPIRED
  CONVERTED
}

model VenueImage {
  id        String   @id @default(cuid())
  url       String
  venueId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

model MaintenanceIssue {
  id         String   @id @default(cuid())
  turfId     String
  venueId    String
  issue      String
  severity   String   @default("Low")
  status     String   @default("Open")
  supervisor String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  turf  Turf  @relation(fields: [turfId], references: [id])
  venue Venue @relation(fields: [venueId], references: [id])
}
